# ─────────────────────────────────────────
# Vriddhi Vastra — .gitignore
# ─────────────────────────────────────────

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build output
/.next/
/out/
/build
/dist
/.turbo

# Test coverage
/coverage

# Environment — NEVER commit secrets
.env
.env.*
.env*.local
.env.development
.env.production
.env.staging

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# OS artifacts
.DS_Store
Thumbs.db
*.pem

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Debug logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# next-sitemap build outputs (regenerated on every deploy)
public/sitemap*.xml
public/robots.txt

# Legacy data files / seed scripts
app/data/
data/
db/
database/
dump/
*.bson

# Dev-only scratch scripts & Temp files
scratch.js
resolve.js
temp_settings.js
*.tmp
temp_*.js
migration*.js
test*.js
mock*.js
